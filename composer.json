{
    "name": "uuki/preview-token",
    "description": "Issues time-limited preview tokens for Headless WordPress.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "symfony/polyfill-php80": "^1.31"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "PVT\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PVT\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
