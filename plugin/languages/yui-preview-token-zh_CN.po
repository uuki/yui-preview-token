msgid "YUI Preview Token"
msgstr "YUI Preview Token"

msgid "External Preview URL"
msgstr "外部预览 URL"

msgid "Allowed Origins (CORS)"
msgstr "允许的来源（CORS）"

msgid "Minimum Capability"
msgstr "最低角色"

msgid "Rate Limit"
msgstr "速率限制"

msgid "Rate Limit Window"
msgstr "速率限制时间窗口"

msgid "Allow No-Expiry Tokens"
msgstr "允许无过期令牌"

msgid "URL of the external client or frontend used to render preview content. Intended for headless setups (e.g. Astro, Next.js, Nuxt) and decoupled architectures where draft content is rendered outside of WordPress. If left empty, the WordPress site URL is used as a fallback."
msgstr "用于渲染预览内容的外部客户端或前端的 URL。适用于无头架构（如 Astro、Next.js、Nuxt）和在 WordPress 外部渲染草稿内容的解耦架构。留空时将使用 WordPress 站点 URL 作为备用。"

msgid "Wildcards are supported (e.g. https://*.example.com, *). Leave all fields empty to disable CORS headers."
msgstr "支持通配符（如 https://*.example.com、*）。将所有字段留空可禁用 CORS 标头。"

msgid "+ Add origin"
msgstr "+ 添加来源"

msgid "Remove this origin"
msgstr "删除此来源"

msgid "Enable"
msgstr "启用"

msgid "Allow preview tokens with no expiry. Use with caution — these tokens persist until manually deleted."
msgstr "允许无过期的预览令牌。请谨慎使用——这些令牌在手动删除之前将一直有效。"

msgid "You do not have sufficient permissions to access this page."
msgstr "您没有足够的权限访问此页面。"

msgid "Subscriber"
msgstr "订阅者"

msgid "Contributor"
msgstr "投稿者"

msgid "Author"
msgstr "作者"

msgid "Editor"
msgstr "编辑"

msgid "Administrator"
msgstr "管理员"

msgid "External Preview"
msgstr "外部预览"

msgid "1 hour"
msgstr "1小时"

msgid "24 hours"
msgstr "24小时"

msgid "30 days"
msgstr "30天"

msgid "Custom"
msgstr "自定义"

msgid "No expiry"
msgstr "永不过期"

msgid "Loading…"
msgstr "加载中…"

msgid "Expiry"
msgstr "过期时间"

msgid "Update"
msgstr "更新"

msgid "Cancel"
msgstr "取消"

msgid "Open external preview"
msgstr "打开外部预览"

msgid "Copy external preview URL"
msgstr "复制外部预览 URL"

msgid "Change expiry"
msgstr "修改过期时间"

msgid "Delete"
msgstr "删除"

msgid "Delete this token?"
msgstr "确认删除此令牌？"

msgid "Yes"
msgstr "确认"

msgid "Generate token"
msgstr "生成令牌"

msgid "Regenerate token"
msgstr "重新生成令牌"

msgid "Token expired: %s"
msgstr "令牌已过期：%s"

msgid "Expires: %1$s (%2$s remaining)"
msgstr "过期时间：%s（剩余 %s）"

msgid "< 1 min"
msgstr "不足1分钟"

msgid "An error occurred"
msgstr "发生错误"

msgid "requests per window"
msgstr "次请求/时间窗口"

msgid "seconds"
msgstr "秒"

#: src/WordPress/Settings.php
msgid "Settings"
msgstr "设置"

#: src/WordPress/Settings.php src/WordPress/TokenAdmin.php
msgid "Issued Tokens"
msgstr "已发行令牌"

#: src/WordPress/Settings.php src/WordPress/TokenAdmin.php
msgid "Security Warning"
msgstr "安全警告"

#: src/WordPress/Settings.php src/WordPress/TokenAdmin.php
msgid "The bare wildcard (*) allows any origin to access draft content via a valid token. Use specific origin patterns whenever possible."
msgstr "使用裸通配符（*）将允许任何来源通过有效令牌访问草稿内容。请尽可能使用具体的来源模式。"

#: src/WordPress/TokenAdmin.php
msgid "Delete Expired"
msgstr "删除已过期"

#: src/WordPress/TokenAdmin.php
msgid "Token revoked."
msgstr "令牌已失效。"

#: src/WordPress/TokenAdmin.php
msgid "Expired tokens deleted."
msgstr "已过期的令牌已删除。"

#: src/WordPress/TokenAdmin.php
msgid "Post"
msgstr "文章"

#: src/WordPress/TokenAdmin.php
msgid "Post Status"
msgstr "文章状态"

#: src/WordPress/TokenAdmin.php
msgid "Token Status"
msgstr "令牌状态"

#: src/WordPress/TokenAdmin.php
msgid "Issued At"
msgstr "发行时间"

#: src/WordPress/TokenAdmin.php
msgid "Expires At"
msgstr "过期时间"

#: src/WordPress/TokenAdmin.php
msgid "Issued By"
msgstr "发行者"

#: src/WordPress/TokenAdmin.php
msgid "Active"
msgstr "有效"

#: src/WordPress/TokenAdmin.php
msgid "Expired"
msgstr "已过期"

#: src/WordPress/TokenAdmin.php
msgid "(no title)"
msgstr "（无标题）"

#: src/WordPress/TokenAdmin.php
msgid "Post deleted"
msgstr "文章已删除"

#: src/WordPress/TokenAdmin.php
msgid "Revoke"
msgstr "撤销"

#: src/WordPress/TokenAdmin.php
msgid "Revoke this token?"
msgstr "确认撤销此令牌？"

#: src/WordPress/TokenAdmin.php
msgid "No tokens have been issued yet."
msgstr "尚未发行任何令牌。"

#. translators: %d: number of tokens
#: src/WordPress/TokenAdmin.php
msgid "%d token(s) issued in total."
msgstr "共发行了 %d 个令牌。"

#: src/WordPress/Settings.php
msgid "Skip HTTPS Check"
msgstr "跳过 HTTPS 检查"

#: src/WordPress/Settings.php
msgid "Enable (development only)"
msgstr "启用（仅限开发环境）"

#: src/WordPress/Settings.php
msgid "By default the preview endpoint requires HTTPS so that tokens cannot be intercepted in transit. Enable this option only when running WordPress on a local development environment where HTTPS is unavailable."
msgstr "默认情况下，预览端点要求使用 HTTPS，以防止令牌在传输过程中被截取。仅在无法使用 HTTPS 的本地开发环境中启用此选项。"

#: src/WordPress/Settings.php
msgid "The HTTPS check is currently disabled. Preview tokens can be sent over unencrypted HTTP. Do not use this setting in a production environment."
msgstr "当前 HTTPS 检查已禁用。预览令牌可能通过未加密的 HTTP 传输。请勿在生产环境中使用此设置。"

#: src/WordPress/Settings.php
msgid "If the %s constant is defined in wp-config.php, it takes precedence over this setting."
msgstr "如果在 wp-config.php 中定义了 %s 常量，则该常量优先于此设置。"

msgid "Maximum number of preview requests allowed from a single IP address within the rate limit window. Requests that exceed this limit receive a 429 response. Default: 30."
msgstr "在速率限制时间窗口内，单个 IP 地址允许的最大预览请求数。超过此限制的请求将收到 429 响应。默认值：30。"

msgid "Time window in seconds over which the rate limit is measured. The request counter resets after each window expires. Default: 60."
msgstr "速率限制的计量时间窗口（秒）。每个窗口到期后，请求计数器将重置。默认值：60。"

msgid "Expired tokens are rejected immediately upon use. However, the database records are removed once daily by WP Cron, so expired tokens may remain visible in this list until the next scheduled cleanup. To remove them right away, use the \"Delete Expired\" button above."
msgstr "已过期的令牌在使用时会被立即拒绝。但是，数据库记录每天由 WP Cron 清理一次，因此过期令牌可能在下次计划清理前仍显示在此列表中。如需立即删除，请使用上方的「删除已过期」按钮。"

msgid "Save your draft before opening the external preview to ensure the latest content is reflected."
msgstr "请在打开外部预览前保存草稿，以确保显示最新内容。"

msgid "Preview is only available for unpublished posts."
msgstr "预览仅适用于未发布的文章。"

msgid "Too many requests."
msgstr "请求过多。"

msgid "Token issuance from external clients is not enabled. Enable \"Allow External Token Issuance\" in Settings → YUI Preview Token."
msgstr "未启用从外部客户端发行令牌。请在「设置 → YUI Preview Token」中启用「允许从外部发行令牌」。"

msgid "Token issuance from external clients is not enabled."
msgstr "未启用从外部客户端发行令牌。"

msgid "No active token for this post."
msgstr "此文章没有有效的令牌。"

msgid "Insufficient permissions."
msgstr "权限不足。"

msgid "Post not found."
msgstr "文章未找到。"

msgid "No-expiry tokens are not enabled on this site."
msgstr "此站点未启用无过期时间的令牌。"

msgid "HTTPS is required."
msgstr "需要 HTTPS。"

msgid "Invalid or expired preview token."
msgstr "无效或已过期的预览令牌。"

msgid "Allow External Token Issuance"
msgstr "允许从外部发行令牌"

msgid "When enabled, authenticated users with the required role can issue tokens via the REST API from outside the WordPress admin — for example from CI/CD pipelines or automated scripts. When disabled (default), token issuance is restricted to the WordPress admin interface."
msgstr "启用后，具有所需角色的已认证用户可以通过 REST API 从 WordPress 管理界面外部发行令牌（例如 CI/CD 流水线或自动化脚本）。禁用时（默认），令牌发行仅限于 WordPress 管理界面。"

msgid "Issues short-lived preview tokens for Headless WordPress preview authentication."
msgstr "为 Headless WordPress 预览认证发行短期有效的预览令牌。"
